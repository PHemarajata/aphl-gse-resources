{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": "public",
    "rewrites": [
      {
        "source": "/api/categorize-resource",
        "function": "categorizeResource"
      },
      {
        "source": "/api/ai-health",
        "function": "aiHealth"
      },
      {
        "source": "/api/saveResources",
        "function": "saveResources"
      }
    ],
    "predeploy": [
      "node scripts/validate-resources.mjs"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
